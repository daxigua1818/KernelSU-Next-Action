# ===============================
# 一加6T 氢OS 11.1.2.2（安卓11 / 内核4.9）
# ===============================

# 内核源码
KERNEL_SOURCE=https://github.com/LineageOS/android_kernel_oneplus_sdm845
KERNEL_BRANCH=lineage-18.1
KERNEL_DEFCONFIG=lineageos_sdm845_defconfig
ARCH=arm64
KERNEL_IMAGE_NAME=Image.gz-dtb

# 工具链（4.9 内核用 GCC 4.9 最稳）
ENABLE_GCC_64=true
ENABLE_CLANG=false

# KernelSU Next
ENABLE_KERNELSU_NEXT=true
KERNELSU_NEXT_BRANCH=next
KERNELSU_NEXT_NON_GKI=true

# 必须开启的内核选项
ADD_KPROBES_CONFIG=true
ADD_OVERLAYFS_CONFIG=true

# 关闭 LTO（4.9 不支持）
DISABLE_LTO=true

# GCC 交叉编译前缀
CROSS_COMPILE=aarch64-linux-android-
