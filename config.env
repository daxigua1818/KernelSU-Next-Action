# ========== 一加6T / 安卓11 / 内核4.9 ==========

KERNEL_SOURCE=https://github.com/LineageOS/android_kernel_oneplus_sdm845
KERNEL_SOURCE_BRANCH=lineage-18.1
KERNEL_CONFIG=lineageos_sdm845_defconfig
KERNEL_IMAGE_NAME=Image.gz-dtb
ARCH=arm64

ENABLE_KERNELSU=true
KERNELSU_TAG=main

DISABLE-LTO=true
ADD_OVERLAYFS_CONFIG=true
DISABLE_CC_WERROR=true
ENABLE_CCACHE=false

NEED_DTBO=false
BUILD_BOOT_IMG=false
SOURCE_BOOT_IMAGE=

ENABLE_LXC=false
ENABLE_NETHUNTER=false
